
    <Page x:Class="WpfAppClientAdmin.Pages.Categories.PageUpdateCategory"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfAppClientAdmin.Pages.Categories"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="PageUpdateCategory">

    <Grid Background="#F7F7F7" Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Categories"
                   Grid.Row="0"
                   FontSize="28"
                   FontWeight="Bold"
                   Margin="0 0 0 20"/>

        <ListView Grid.Row="1"
                  Name="CategoryListView"
                  BorderThickness="0">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="#DDD"
                BorderThickness="1"
                Padding="10"
                CornerRadius="8"
                Margin="0 0 0 10"
                Background="White">

                        <Grid>
                            <!-- מצב תצוגה -->
                            <Grid x:Name="ViewMode">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- תמונה -->
                                <Image Source="{Binding DisplayImagePath}"
                           Width="100"
                           Height="100"
                           Margin="0 0 20 0"
                           Grid.Column="0"/>

                                <!-- שם קטגוריה -->
                                <TextBlock Grid.Column="1"
                               Text="{Binding CategoryName}"
                               FontSize="20"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>

                                <!-- כפתורים -->
                                <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                                    <Button Content="Edit"
                                Width="80"
                                Margin="0 0 10 0"
                                Click="EditInline_Click"/>
                                    <Button Content="Delete"
                                Width="80"
                                Click="DeleteButton_Click"/>
                                </StackPanel>
                            </Grid>

                            <!-- מצב עריכה -->
                            <Grid x:Name="EditMode">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Category name:"/>
                                    <TextBox Text="{Binding CategoryName, Mode=TwoWay}"
                 Width="220"
                 Margin="0 0 10 10"/>

                                    <!-- תצוגת תמונה בזמן עריכה -->
                                    <TextBlock Text="Category image:"/>
                                    <Image Source="{Binding DisplayImagePath}"
               Width="100"
               Height="100"
               Margin="0 0 10 5"/>

                                    <!-- כפתור להחלפת תמונה -->
                                    <Button Content="Change Image"
                Width="120"
                Click="ChangeImage_Click"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1"
                Orientation="Horizontal"
                VerticalAlignment="Bottom">
                                    <Button Content="Save"
                Width="70"
                Margin="0 0 10 0"
                Click="SaveInline_Click"/>
                                    <Button Content="Cancel"
                Width="70"
                Click="CancelInline_Click"/>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- כאן שמים את הטריגרים – בתוך DataTemplate.Triggers -->
                    <DataTemplate.Triggers>
                        <!-- כש-IsEditing = True → מצב עריכה -->
                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                            <Setter TargetName="ViewMode"
                        Property="Visibility"
                        Value="Collapsed"/>
                            <Setter TargetName="EditMode"
                        Property="Visibility"
                        Value="Visible"/>
                        </DataTrigger>

                        <!-- כש-IsEditing = False → מצב תצוגה -->
                        <DataTrigger Binding="{Binding IsEditing}" Value="False">
                            <Setter TargetName="ViewMode"
                        Property="Visibility"
                        Value="Visible"/>
                            <Setter TargetName="EditMode"
                        Property="Visibility"
                        Value="Collapsed"/>
                        </DataTrigger>
                    </DataTemplate.Triggers>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
