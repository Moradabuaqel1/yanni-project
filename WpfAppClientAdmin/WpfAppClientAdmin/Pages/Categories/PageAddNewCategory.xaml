<Page x:Class="WpfAppClientAdmin.Pages.Categories.PageAddNewCategory"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfAppClientAdmin.Pages.Categories"
      mc:Ignorable="d" 
      d:DesignHeight="560" d:DesignWidth="520"
      Title="PageAddNewCategory" 
      Background="#F2F2F2">

    <Grid Margin="0,0,0,10">
        <StackPanel Margin="0,0,0,-21">
            <!--Header-->
            <TextBlock Text="Add New Category"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="#444"
                       Margin="0 0 0 20"
                       HorizontalAlignment="Center"/>
            <!--Label-->
            <TextBlock Text="Please write category name : "
                       FontSize="14"
                       Foreground="#666"
                       Margin="0 0 0 5"/>
            <!--Text Box-->
            <TextBox x:Name="txtCatName"
                     Height="35"
                     Padding="5"
                     FontSize="14"
                     Background="#FAFAFA"
                     BorderBrush="#CCC"
                     Margin="0 0 0 20"
                     BorderThickness="1"/>
            <!-- Button Upload image -->
            <Button Content="Upload Image"
                    Height="40"
                    Background="#4A90E2"
                    Foreground="White"
                    FontWeight="SemiBold"
                    FontSize="14"
                    BorderThickness="0"
                    Cursor="Hand"
                    HorizontalAlignment="Center"
                    Width="200"
                    Click="BtnUploadImage_Click"
                    Margin="0 0 0 10">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="10">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3A7BC8"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <!-- Image -->
            <Image x:Name="Photo" Width="100" Height="120" Margin="5"/>
            <TextBlock x:Name="txtImageName" HorizontalAlignment="Center" Margin="0 5 0 15"/>
            
            <!-- Save Button-->
            <Button Content="Save Image"
                    Height="40"
                    Background="#FF6B6B"
                    Foreground="White"
                    FontWeight="SemiBold"
                    FontSize="14"
                    BorderThickness="0"
                    Cursor="Hand"
                    HorizontalAlignment="Center"
                    Width="200"
                    Click="BtnSave_Click"
                    Margin="0 0 0 10">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="10">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF4E4E"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>
    </Grid>
</Page>
