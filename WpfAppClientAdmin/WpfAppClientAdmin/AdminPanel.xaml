<Window x:Class="WpfAppClientAdmin.AdminPanel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfAppClientAdmin"
        mc:Ignorable="d"
        Title="AdminPanel" Height="450" Width="800">
    <Window.Resources>
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="DarkSlateGray"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>
        <Style x:Key="SubMenuButtonStyle" TargetType="Button" BasedOn="{StaticResource MenuButtonStyle}">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="DimGray"/>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="40"/>
        </Grid.RowDefinitions>
        <!-- Header -->
        <Border Background="SteelBlue" Grid.Row="0" Grid.ColumnSpan="2">
            <TextBlock x:Name="AdminEm" Text="Admin Panel - " Foreground="White"
                     FontSize="24" FontWeight="Bold" VerticalAlignment="Center"
                     TextAlignment="Center"/>
        </Border>
        <!-- Sidebar Menu -->
        <StackPanel Grid.Row="1" Grid.Column="0" Background="LightSlateGray" Margin="2,0">
            <Button Content="Main Page" Click="MainPage_Click" Style="{StaticResource MenuButtonStyle}"/>
            <Expander Header="Admins" Foreground="White">
                <StackPanel>
                    <Button Content="Add New Admin" Click="AddAdmin_Click"
                            Style="{StaticResource SubMenuButtonStyle}"/>
                    <Button Content="Update Admin" Click="UpdateAdmin_Click"
                            Style="{StaticResource SubMenuButtonStyle}"/>
                    <Button Content="Delete Admin" Click="DeleteAdmin_Click"
                            Style="{StaticResource SubMenuButtonStyle}"/>
                    <Button Content="Search Admin" Click="SearchAdmin_Click"
                            Style="{StaticResource SubMenuButtonStyle}"/>
                </StackPanel>
            </Expander>
            <Expander Header="Categories" Foreground="White">
                <StackPanel>
                    <Button Content="Add New Category" Click="AddCategory_Click"
                            Style="{StaticResource SubMenuButtonStyle}"/>
                    <Button Content="Update/Delete/Search" Click="UpdateCategory_Click"
                            Style="{StaticResource SubMenuButtonStyle}"/>
                </StackPanel>
            </Expander>
            <Expander Header="Products" Foreground="White">
                <StackPanel>
                    <Button Content="Add New Product" Click="AddProduct_Click"
                            Style="{StaticResource SubMenuButtonStyle}"/>
                    <Button Content="Update/Delete/Search" Click="UpdateProduct_Click"
                            Style="{StaticResource SubMenuButtonStyle}"/>
                </StackPanel>
            </Expander>
            <Button Content="Logout" Click="Logout_Click" 
                    Style="{StaticResource MenuButtonStyle}" Background="Tomato"/>
        </StackPanel>
        <!-- Main Content -->
        <Frame x:Name="MainContent" Grid.Row="1" Grid.Column="1" Margin="10"
               Background="White" NavigationUIVisibility="Hidden"/>
    </Grid>
</Window>
